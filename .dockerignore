# Keep the build context small and, crucially, prevent the host's Windows-native
# node_modules from being copied into the Linux image (it would clobber the
# Linux install and fail at runtime).
node_modules
dist
.git
*.log

# Personal tracker data and recovery copies must never enter an image layer.
local-data/
backup_*.json
backup_*.sqlite
*tracker-backup*.json
summer-rescue-tracker-state.json
progress-log*.ndjson
*.sqlite

# Local university materials are mounted/served on the host and are not image assets.
public/study-assets/

# Local QA output.
.chrome-smoke*/
.edge-smoke*/
*.png.tmp
